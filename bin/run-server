#!/bin/bash
set -e

# Run standard Django preparation
python manage.py migrate
python manage.py collectstatic --no-input

# Start Granian with ASGI interface
exec granian --interface asgi finis.asgi:application \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 4 \
    --threads 4 \
    --http 2 \
    --backlog 1024
