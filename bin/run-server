#!/bin/bash
set -e

# Run standard Django preparation
uv run manage.py migrate
uv run manage.py collectstatic --no-input

# Start Granian with ASGI interface
# Use --host 0.0.0.0 for containerized environments
exec uv run granian --interface asgi finis.asgi:application \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 4 \
    --threads 4 \
    --http 2 \
    --backlog 1024
