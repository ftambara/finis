### Go ###
# Source: https://github.com/github/gitignore/blob/main/Go.gitignore

# Binaries for programs and plugins
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

### Editor/IDE ###
.idea/
.vscode/
