# https://ssl-config.mozilla.org/#server=caddy&version=2.11&config=modern&guideline=5.7

{$SITE_DOMAIN:localhost} {
  # Enforce TLS 1.3 only
  tls {
    protocols tls1.3
  }

  # HSTS (63072000 seconds)
  header Strict-Transport-Security "max-age=63072000"

  # Route static and media files
  handle_path /static/* {
    root * /var/www/static
    file_server
  }
  handle_path /media/* {
    root * /var/www/media
    file_server
  }

  # Reverse proxy to Django application
  handle {
    request_body {
      max_size 50MB
    }
    reverse_proxy {$UPSTREAM_ADDR:app:8000} {
      header_up X-Real-IP {remote_host}
    }
  }

  # Logging
  log {
    output stdout
    format json
  }
}

